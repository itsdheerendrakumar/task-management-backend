// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  projectManager
  client
  member
}

enum ChatType {
  private
  group
}

enum TaskStatus {
  pending
  completed
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  name          String?
  role          Role     @default(member)
  password      String
  profile_image String?
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now()) @updatedAt

  session           Session[]
  task              Task[]
  subtask           Subtask[]
  task_participants TaskParticipants[]
  chat              Chats[]
  chat_participant  ChatParticipants[]
  message           Messages[]
}

model Session {
  id            String   @id
  user_id       Int
  refresh_token String
  expires_at    DateTime

  user User @relation(fields: [user_id], references: [id])
}

model Task {
  id                Int                @id @default(autoincrement())
  name              String
  description       String
  deadline          DateTime
  notes             String
  created_by        Int
  created_at        DateTime           @default(now())
  updated_at        DateTime           @default(now()) @updatedAt
  status            TaskStatus
  subtask           Subtask[]
  task_participants TaskParticipants[]

  creater User @relation(fields: [created_by], references: [id])
}

model Subtask {
  id          Int        @id @default(autoincrement())
  name        String
  description String
  status      TaskStatus
  task_id     Int
  created_by  Int
  created_at  DateTime   @default(now())
  updated_at  DateTime   @default(now()) @updatedAt

  creater User @relation(fields: [created_by], references: [id])
  task    Task @relation(fields: [task_id], references: [id])
}

model TaskParticipants {
  user_id Int
  role    Role
  task_id Int

  user User @relation(fields: [user_id], references: [id])
  task Task @relation(fields: [task_id], references: [id])

  @@id([task_id, user_id])
}

model Chats {
  id         Int      @id @default(autoincrement())
  type       ChatType @default(private)
  name       String?
  image_url  String?
  created_by Int?
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  user             User?              @relation(fields: [created_by], references: [id])
  chat_participant ChatParticipants[]
  message          Messages[]
}

model ChatParticipants {
  id           Int      @id @default(autoincrement())
  chat_id      Int
  user_id      Int
  joined_at    DateTime @default(now())
  last_read_at DateTime

  chat Chats @relation(fields: [chat_id], references: [id])
  user User  @relation(fields: [user_id], references: [id])
}

model Messages {
  id         Int      @id @default(autoincrement())
  chat_id    Int
  sender_id  Int
  content    String?
  file       String?
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  deleted_at DateTime

  chat Chats @relation(fields: [chat_id], references: [id])
  user User  @relation(fields: [sender_id], references: [id])
}
